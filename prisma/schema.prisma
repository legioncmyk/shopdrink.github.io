generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Product {
  id          String      @id @default(cuid())
  name        String
  description String      @default("")
  price       Float
  image       String      @default("")
  stockStatus String      @default("available")
  category    String      @default("Minuman")
  featured    Boolean     @default(false)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  orderItems  OrderItem[]
}

model Order {
  id            String   @id @default(cuid())
  orderNumber   String   @unique
  customerName  String
  phone         String
  notes         String   @default("")
  totalPrice    Float
  status        String   @default("menunggu_pembayaran")
  paymentMethod String   @default("dana")
  paymentProof  String   @default("")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  items         OrderItem[]
}

model OrderItem {
  id         String @id @default(cuid())
  orderId    String
  productId  String
  productName String
  price      Float
  quantity   Int
  order      Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product    Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model Banner {
  id        String   @id @default(cuid())
  image     String
  title     String   @default("")
  linkText  String   @default("Pesan Sekarang")
  sortOrder Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
}

model Promo {
  id          String   @id @default(cuid())
  title       String
  description String   @default("")
  image       String   @default("")
  discount    String   @default("")
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
}

model Setting {
  id    String @id @default(cuid())
  key   String @unique
  value String
}
